# Bash scripts must always use LF line endings
*.sh text eol=lf
build-dist.sh text eol=lf

# Standard text files
*.md text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Binary files
*.exe binary
*.png binary
*.ico binary
*.icns binary
*.node binary
*.db binary
